# Copiez ce fichier en .env et remplissez vos vraies clés
# Ne jamais commiter .env dans git

# Clé API Anthropic (pour le chatbot IDS)
# Obtenez-la sur : https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optionnel : configuration email pour les alertes
# MAIL_USER=votre@email.com
# MAIL_PASS=votre_mot_de_passe
